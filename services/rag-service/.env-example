APP_NAME=rag-service
ENVIRONMENT=dev
LOG_LEVEL=INFO

HTTP_PORT=8001

INTERNAL_MCP_TOKEN=dev-internal-token
ALLOWED_MCP_ORIGINS_RAW=http://gateway-api.internal,http://127.0.0.1:8000,http://localhost:8000

# POSTGRES_DSN=postgresql://app_user:app_password@127.0.0.1:5432/ragdb
POSTGRES_DSN=postgresql://app_user:app_password@postgres:5432/ragdb
PGVECTOR_DIMENSION=128

RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.0
MAX_CONTEXT_CHARS=6000

EMBEDDING_PROVIDER=hash
GENERATOR_PROVIDER=stub